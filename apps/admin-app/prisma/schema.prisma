// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  id            String          @id @default(cuid())
  shopDomain    String          @unique
  installedAt   DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  uninstalledAt DateTime?
  appInstalled  Boolean         @default(true)
  settings      ShopSettings?
  onboarding    OnboardingState?
  whatsappConnection ShopWhatsappConnection?
  whatsappTemplates ShopWhatsappTemplate[]
  webhookEvents      WebhookEvent[]
  outboundMessages   OutboundMessage[]
  outboundCallbacks  OutboundMessageCallback[]
  orderConfirmations OrderConfirmation[]
  orderStatusUpdates  OrderStatusUpdate[]
  cartRecoveries      CartRecovery[]
  campaignSettings    CampaignSettings?
  broadcastCampaigns  BroadcastCampaign[]
  campaignRecipients  BroadcastCampaignRecipient[]
  campaignDispatchLogs BroadcastCampaignDispatchLog[]
  workflows          Workflow[]
  workflowRuns       WorkflowRun[]
}




model ShopSettings {
  id             String   @id @default(cuid())
  shopId         String   @unique
  contactEmail   String?
  defaultCountry String?
  timezone       String?
  orderConfirmationEnabled Boolean @default(false)
  orderConfirmationTemplateKey String?
  orderStatusUpdatesEnabled Boolean @default(false)
  orderStatusTemplatePartialFulfilled String?
  orderStatusTemplateFulfilled String?
  orderStatusTemplateOutForDelivery String?
  orderStatusTemplateDelivered String?
  orderStatusTemplateCancelled String?
  cartRecoveryEnabled Boolean @default(false)
  cartRecoveryTemplateKey String?
  cartRecoveryWaitMinutes Int @default(60)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  shop           Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model OnboardingState {
  id                          String   @id @default(cuid())
  shopId                      String   @unique
  currentStep                 String   @default("identity_confirmed")
  checklistIdentityComplete   Boolean  @default(true)
  checklistSettingsComplete   Boolean  @default(false)
  checklistBillingComplete    Boolean  @default(false)
  readinessSettingsConfigured Boolean  @default(false)
  readinessWhatsappConnected  Boolean  @default(false)
  readinessTemplatesReady     Boolean  @default(false)
  readinessAutomationsReady   Boolean  @default(false)
  completedAt                 DateTime?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  shop                        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
}



model ShopWhatsappConnection {
  id                  String                            @id @default(cuid())
  shopId              String                            @unique
  businessAccountId   String?
  phoneNumberId       String?
  displayPhoneNumber  String?
  connectionStatus    WhatsAppConnectionStatus          @default(NOT_CONNECTED)
  syncStatus          WhatsAppTemplateSyncStatus        @default(NOT_STARTED)
  lastSyncedAt        DateTime?
  configurationNotes  String?
  errorState          String?
  templateSyncRequested Boolean                         @default(false)
  authStateNonce      String?
  authRequestedAt     DateTime?
  authFailureReason   String?
  providerAccessToken String?
  providerTokenType   String?
  providerTokenExpiresAt DateTime?
  providerUserId      String?
  providerConnectedAt DateTime?
  createdAt           DateTime                          @default(now())
  updatedAt           DateTime                          @updatedAt
  shop                Shop                              @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model ShopWhatsappTemplate {
  id                 String   @id @default(cuid())
  shopId             String
  templateKey        String
  providerTemplateId String?
  name               String
  category           String
  language           String
  status             String
  header             String
  body               String
  footer             String?
  syncedAt           DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  shop               Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, templateKey])
  @@index([shopId, status])
}

enum WhatsAppConnectionStatus {
  NOT_CONNECTED
  INCOMPLETE_SETUP
  MISCONFIGURED
  SYNC_NEEDED
  CONNECTED
}

enum WhatsAppTemplateSyncStatus {
  NOT_STARTED
  PENDING
  IN_SYNC
  NEEDS_ATTENTION
  FAILED
}

model OutboundMessage {
  id                    String                   @id @default(cuid())
  shopDomain            String
  channel               MessageChannel
  useCase               String
  idempotencyKey        String?                  @unique
  recipientAddress      String
  payload               String
  templateKey           String?
  metadata              String?
  providerName          String
  providerMessageId     String?
  status                OutboundMessageStatus    @default(PENDING)
  statusReason          String?
  retryClass            RetryClass               @default(NON_RETRYABLE)
  retryCount            Int                      @default(0)
  maxRetryCount         Int                      @default(3)
  nextRetryAt           DateTime?
  lockedAt              DateTime?
  callbackCorrelationId String?
  deadLetteredAt        DateTime?
  escalatedAt           DateTime?
  createdAt             DateTime                 @default(now())
  sentAt                DateTime?
  deliveredAt           DateTime?
  failedAt              DateTime?
  updatedAt             DateTime                 @updatedAt
  attempts              OutboundMessageAttempt[]
  callbacks             OutboundMessageCallback[]
  orderConfirmations    OrderConfirmation[]
  orderStatusUpdates    OrderStatusUpdate[]
  campaignRecipients    BroadcastCampaignRecipient[]
  cartRecoveries        CartRecovery[]
  shop                  Shop                     @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)

  @@index([shopDomain, status, createdAt])
  @@index([status, nextRetryAt])
  @@index([providerName, providerMessageId])
}

model OutboundMessageAttempt {
  id              String                @id @default(cuid())
  outboundMessageId String
  attemptNumber   Int
  providerName    String
  providerMessageId String?
  status          AttemptStatus         @default(INITIATED)
  requestPayload  String
  responsePayload String?
  errorCode       String?
  errorMessage    String?
  retryClass      RetryClass            @default(NON_RETRYABLE)
  startedAt       DateTime              @default(now())
  completedAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  outboundMessage OutboundMessage       @relation(fields: [outboundMessageId], references: [id], onDelete: Cascade)

  @@unique([outboundMessageId, attemptNumber])
  @@index([status, startedAt])
}

model OutboundMessageCallback {
  id                    String             @id @default(cuid())
  shopDomain            String
  providerName          String
  externalEventId       String?
  callbackCorrelationId String?
  providerMessageId     String?
  eventType             String
  dedupeKey             String             @unique
  payload               String
  headersPayload        String
  status                CallbackEventStatus @default(RECEIVED)
  reconciledMessageId   String?
  reconciliationError   String?
  receivedAt            DateTime           @default(now())
  processedAt           DateTime?
  failedAt              DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  shop                  Shop               @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)
  reconciledMessage     OutboundMessage?   @relation(fields: [reconciledMessageId], references: [id], onDelete: SetNull)

  @@index([providerName, providerMessageId, receivedAt])
  @@index([status, receivedAt])
}


model OrderConfirmation {
  id                     String                    @id @default(cuid())
  shopDomain             String
  orderId                String
  webhookEventId         String
  status                 OrderConfirmationStatus   @default(PENDING)
  statusReason           String?
  templateKey            String?
  recipientPhone         String?
  normalizedOrderPayload String
  outboundMessageId      String?                   @unique
  createdAt              DateTime                  @default(now())
  processedAt            DateTime?
  failedAt               DateTime?
  updatedAt              DateTime                  @updatedAt
  shop                   Shop                      @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)
  outboundMessage        OutboundMessage?          @relation(fields: [outboundMessageId], references: [id], onDelete: SetNull)

  @@unique([shopDomain, orderId])
  @@index([shopDomain, status, createdAt])
}


model OrderStatusUpdate {
  id                     String                  @id @default(cuid())
  shopDomain             String
  webhookEventId         String
  orderId                String
  statusType             OrderStatusType
  state                  OrderStatusUpdateState  @default(PENDING)
  stateReason            String?
  dedupeKey              String                  @unique
  sourceTopic            String
  sourceReference        String?
  templateKey            String?
  recipientPhone         String?
  normalizedPayload      String
  outboundMessageId      String?                 @unique
  createdAt              DateTime                @default(now())
  processedAt            DateTime?
  failedAt               DateTime?
  updatedAt              DateTime                @updatedAt
  shop                   Shop                    @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)
  outboundMessage        OutboundMessage?        @relation(fields: [outboundMessageId], references: [id], onDelete: SetNull)

  @@unique([shopDomain, orderId, statusType])
  @@index([shopDomain, state, createdAt])
}

model CartRecovery {
  id                     String             @id @default(cuid())
  shopDomain             String
  webhookEventId         String
  checkoutId             String
  checkoutToken          String?
  cartToken              String?
  state                  CartRecoveryState  @default(PENDING_WAIT)
  stateReason            String?
  dedupeKey              String             @unique
  recipientPhone         String?
  customerId             String?
  templateKey            String?
  checkoutSubtotalAmount String?
  checkoutCurrencyCode   String?
  normalizedPayload      String
  recoveryEligibleAt     DateTime
  lastEvaluatedAt        DateTime?
  outboundMessageId      String?            @unique
  sentAt                 DateTime?
  processedAt            DateTime?
  failedAt               DateTime?
  recoveredAt            DateTime?
  recoveredOrderId       String?
  recoveredOrderNumber   String?
  recoveredRevenueAmount String?
  recoveredCurrencyCode  String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  shop                   Shop               @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)
  outboundMessage        OutboundMessage?   @relation(fields: [outboundMessageId], references: [id], onDelete: SetNull)

  @@unique([shopDomain, checkoutId])
  @@index([shopDomain, state, recoveryEligibleAt])
  @@index([shopDomain, recoveredAt])
}


model CampaignSettings {
  id                       String   @id @default(cuid())
  shopId                   String   @unique
  enabled                  Boolean  @default(false)
  defaultTemplateKey       String?
  dispatchBatchSize        Int      @default(20)
  throttleMsBetweenMessages Int     @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  shop                     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model BroadcastCampaign {
  id                String                  @id @default(cuid())
  shopDomain        String
  name              String
  messageBody       String
  templateKey       String?
  audienceType      BroadcastAudienceType
  audienceQuery     String?
  status            BroadcastCampaignStatus @default(DRAFT)
  statusReason      String?
  scheduleAt        DateTime?
  sendNowRequestedAt DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  failedAt          DateTime?
  cancelledAt       DateTime?
  lastDispatchAt    DateTime?
  totalRecipients   Int                     @default(0)
  sentRecipients    Int                     @default(0)
  failedRecipients  Int                     @default(0)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  shop              Shop                    @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)
  recipients        BroadcastCampaignRecipient[]
  dispatchLogs      BroadcastCampaignDispatchLog[]

  @@index([shopDomain, status, scheduleAt])
  @@index([shopDomain, createdAt])
}

model BroadcastCampaignRecipient {
  id                 String                 @id @default(cuid())
  campaignId         String
  shopDomain         String
  recipientAddress   String
  dedupeKey          String                 @unique
  state              BroadcastRecipientState @default(PENDING)
  stateReason        String?
  outboundMessageId  String?                @unique
  dispatchAttemptCount Int                  @default(0)
  lastDispatchedAt   DateTime?
  sentAt             DateTime?
  failedAt           DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  campaign           BroadcastCampaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  shop               Shop                   @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)
  outboundMessage    OutboundMessage?       @relation(fields: [outboundMessageId], references: [id], onDelete: SetNull)

  @@unique([campaignId, recipientAddress])
  @@index([campaignId, state, createdAt])
  @@index([shopDomain, state, updatedAt])
}

model BroadcastCampaignDispatchLog {
  id          String                @id @default(cuid())
  campaignId  String
  shopDomain  String
  level       BroadcastLogLevel
  eventType   String
  message     String
  metadata    String?
  createdAt   DateTime              @default(now())
  campaign    BroadcastCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  shop        Shop                  @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)

  @@index([shopDomain, createdAt])
  @@index([campaignId, createdAt])
}


model Workflow {
  id                    String          @id @default(cuid())
  shopDomain            String
  name                  String
  description           String?
  status                WorkflowStatus  @default(DRAFT)
  definitionJson        String
  validationErrorsJson  String?
  lastValidatedAt       DateTime?
  publishedAt           DateTime?
  pausedAt              DateTime?
  archivedAt            DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  shop                  Shop            @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)
  runs                  WorkflowRun[]

  @@index([shopDomain, status, createdAt])
}

model WorkflowRun {
  id                  String             @id @default(cuid())
  workflowId          String
  shopDomain          String
  triggerType         WorkflowTriggerType
  status              WorkflowRunStatus  @default(PENDING)
  triggerPayloadJson  String?
  executionLogJson    String?
  failedStepId        String?
  failureReason       String?
  startedAt           DateTime?
  completedAt         DateTime?
  failedAt            DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  workflow            Workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  shop                Shop               @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)

  @@index([shopDomain, status, createdAt])
  @@index([workflowId, createdAt])
}

model WebhookEvent {
  id                   String                @id @default(cuid())
  source               WebhookSource
  topic                String
  shopDomain           String
  externalEventId      String?
  dedupeKey            String                @unique
  rawPayload           String
  headersPayload       String
  normalizedPayload    String
  normalizationVersion Int                   @default(1)
  processingStatus     WebhookProcessingStatus @default(RECEIVED)
  receivedAt           DateTime              @default(now())
  enqueuedAt           DateTime?
  processedAt          DateTime?
  failedAt             DateTime?
  failureReason        String?
  failureCount         Int                   @default(0)
  deadLetteredAt       DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  shop                 Shop                  @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)
  queueItem            WebhookQueueItem?

  @@index([shopDomain, topic, receivedAt])
  @@index([processingStatus, receivedAt])
}

model WebhookQueueItem {
  id             String             @id @default(cuid())
  webhookEventId String             @unique
  queueName      String
  status         QueueStatus        @default(PENDING)
  availableAt    DateTime           @default(now())
  lockedAt       DateTime?
  attempts       Int                @default(0)
  lastError      String?
  deadLetteredAt DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  webhookEvent   WebhookEvent       @relation(fields: [webhookEventId], references: [id], onDelete: Cascade)

  @@index([status, availableAt])
}


enum WorkflowStatus {
  DRAFT
  PUBLISHED
  PAUSED
  ARCHIVED
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum WorkflowTriggerType {
  ORDER_CREATED
  ORDER_UPDATED
  CHECKOUT_ABANDONED
  MANUAL
}

enum WebhookSource {
  SHOPIFY
}

enum WebhookProcessingStatus {
  RECEIVED
  ENQUEUED
  PROCESSING
  PROCESSED
  FAILED
  DEAD_LETTER
}

enum OrderConfirmationStatus {
  PENDING
  SKIPPED_DISABLED
  SKIPPED_NOT_ELIGIBLE
  QUEUED
  SENT
  FAILED
}

enum QueueStatus {
  PENDING
  PROCESSING
  FAILED
  DEAD_LETTER
  DONE
}

enum MessageChannel {
  WHATSAPP
}

enum OutboundMessageStatus {
  PENDING
  SENDING
  SENT
  DELIVERED
  FAILED
  RETRY_SCHEDULED
  DEAD_LETTER
}

enum AttemptStatus {
  INITIATED
  SUCCEEDED
  FAILED
}

enum RetryClass {
  TRANSIENT
  RATE_LIMITED
  PROVIDER_UNAVAILABLE
  NON_RETRYABLE
}

enum CallbackEventStatus {
  RECEIVED
  RECONCILED
  FAILED
}

enum OrderStatusType {
  ORDER_PARTIALLY_FULFILLED
  ORDER_FULFILLED
  ORDER_OUT_FOR_DELIVERY
  ORDER_DELIVERED
  ORDER_CANCELLED
}

enum OrderStatusUpdateState {
  PENDING
  SKIPPED_DISABLED
  SKIPPED_NOT_ELIGIBLE
  SKIPPED_MISSING_TEMPLATE
  DUPLICATE_SUPPRESSED
  QUEUED
  SENT
  FAILED
}

enum CartRecoveryState {
  PENDING_WAIT
  SKIPPED_DISABLED
  SKIPPED_NOT_ELIGIBLE
  SKIPPED_MISSING_TEMPLATE
  DUPLICATE_SUPPRESSED
  QUEUED
  SENT
  FAILED
  RECOVERED
}

enum BroadcastAudienceType {
  ALL_KNOWN_CONTACTS
  RECENT_ORDER_CONTACTS
  MANUAL_CONTACTS
}

enum BroadcastCampaignStatus {
  DRAFT
  SCHEDULED
  QUEUED
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum BroadcastRecipientState {
  PENDING
  SENT
  FAILED
  SKIPPED_DUPLICATE
}

enum BroadcastLogLevel {
  INFO
  WARN
  ERROR
}
