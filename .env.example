# --------------------------------------------------
# App
# --------------------------------------------------
NODE_ENV=development
APP_NAME=shopify-whatsapp-app
APP_ENV=local

# --------------------------------------------------
# URLs
# --------------------------------------------------
APP_BASE_URL=http://localhost:3000
ADMIN_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
WEBHOOK_BASE_URL=http://localhost:4000
SHOPIFY_APP_URL=http://localhost:3000

# --------------------------------------------------
# Shopify
# --------------------------------------------------
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_HANDLE=
SHOPIFY_APP_SCOPES=
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_API_VERSION=

# --------------------------------------------------
# Meta / WhatsApp
# --------------------------------------------------
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_SECRET=

# --------------------------------------------------
# Database
# --------------------------------------------------
DATABASE_URL=

# --------------------------------------------------
# Queue / Workers
# --------------------------------------------------
QUEUE_BACKEND=redis
REDIS_URL=
WORKER_CONCURRENCY=5

# --------------------------------------------------
# Auth / Session
# --------------------------------------------------
SESSION_SECRET=

# --------------------------------------------------
# Logging / Monitoring
# --------------------------------------------------
LOG_LEVEL=info
SENTRY_DSN=
MONITORING_ENV=local

# --------------------------------------------------
# Feature flags
# --------------------------------------------------
ENABLE_ORDER_CONFIRMATION=true
ENABLE_ORDER_STATUS_UPDATES=true
ENABLE_ABANDONED_CART=true
ENABLE_BROADCASTS=true
ENABLE_WORKFLOW_BUILDER=true
ENABLE_ANALYTICS=true

# --------------------------------------------------
# Analytics / Internal
# --------------------------------------------------
DEFAULT_TIMEZONE=UTC
DEFAULT_LOCALE=en